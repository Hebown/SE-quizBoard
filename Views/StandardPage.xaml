<Page
    x:Class="QuizNative.Views.StandardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:QuizNative.ViewModels"
    mc:Ignorable="d">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240" />
            <ColumnDefinition Width="1" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ===== 左侧章节列表 ===== -->
        <Grid Grid.Column="0" Padding="12,16,12,16" RowSpacing="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="章节选择"
                       Style="{StaticResource SubtitleTextBlockStyle}"
                       FontWeight="SemiBold"
                       FontSize="16" />

            <ListView Grid.Row="1"
                      x:Name="ChapterListView"
                      ItemsSource="{x:Bind ViewModel.Chapters}"
                      SelectionMode="Single"
                      SelectionChanged="ChapterListView_SelectionChanged"
                      Margin="0,6,0,0">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="vm:ChapterItem">
                        <Grid Padding="4,6">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE8B7;"
                                          FontSize="14"
                                          Foreground="{ThemeResource SystemAccentColor}" />
                                <TextBlock Text="{x:Bind DisplayText}"
                                           VerticalAlignment="Center"
                                           Style="{StaticResource BodyTextBlockStyle}"
                                           FontSize="14" />
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>

        <!-- ===== 分隔线 ===== -->
        <Border Grid.Column="1"
                Background="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                Width="1"
                Margin="0,16"
                Opacity="0.3" />

        <!-- ===== 右侧内容区 ===== -->
        <Grid Grid.Column="2" Padding="24,16,24,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="56" />
            </Grid.RowDefinitions>

            <!-- Row 0: 题目区 -->
            <Grid Grid.Row="0" Margin="0,0,16,8">
                <StackPanel x:Name="EmptyPanel" Visibility="Visible"
                            HorizontalAlignment="Center" VerticalAlignment="Center"
                            Spacing="8">
                    <FontIcon Glyph="&#xE9CE;" FontSize="40"
                              Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                    <TextBlock Text="请在左侧选择章节开始刷题"
                               Style="{StaticResource BodyLargeTextBlockStyle}"
                               Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                </StackPanel>

                <ScrollViewer x:Name="QuestionScrollViewer" Visibility="Collapsed"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="QuestionPanel"
                                HorizontalAlignment="Left" Spacing="12"
                                MaxWidth="720">
                        <!-- 进度头 -->
                        <StackPanel Spacing="4" Margin="0,8,0,16">
                            <TextBlock x:Name="ProgressHeader"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"
                                       FontSize="12" />

                            <!-- 题型标签 -->
                            <TextBlock x:Name="TypeLabel"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource SystemAccentColor}"
                                       FontWeight="Bold"
                                       FontSize="12" />

                            <!-- 英文题干（缩小字号） -->
                            <TextBlock x:Name="TopicText"
                                       Style="{StaticResource BodyLargeTextBlockStyle}"
                                       TextWrapping="Wrap"
                                       FontSize="16"
                                       FontWeight="Normal"
                                       LineHeight="26" />

                            <!-- 中文翻译（无 icon） -->
                            <TextBlock x:Name="TranslationText"
                                       Style="{StaticResource BodyTextBlockStyle}"
                                       TextWrapping="Wrap"
                                       Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"
                                       FontStyle="Italic"
                                       FontSize="14"
                                       Visibility="Collapsed" />
                        </StackPanel>

                        <!-- 单选/判断题选项按钮 -->
                        <ItemsControl x:Name="OptionsList" Margin="0,2,0,0" />

                        <!-- 多选题选项（复选框） -->
                        <ItemsControl x:Name="MultipleOptionsList" Margin="0,2,0,0" Visibility="Collapsed" />

                        <!-- 多选题提交按钮 -->
                        <Button x:Name="SubmitMultipleButton"
                                Content="提交多选题答案"
                                HorizontalAlignment="Stretch"
                                Margin="0,6,0,0"
                                Padding="12,8"
                                CornerRadius="4"
                                Style="{StaticResource AccentButtonStyle}"
                                Visibility="Collapsed"
                                Click="SubmitMultipleButton_Click" />

                        <!-- 解析内容（回答后自动显示） -->
                        <Border x:Name="ExplanationPanel"
                                Visibility="Collapsed"
                                Background="{ThemeResource SystemControlAcrylicWindowBrush}"
                                CornerRadius="4"
                                Padding="12,8"
                                Margin="0,2,0,0">
                            <StackPanel Spacing="6">
                                <TextBlock Text="题目解析"
                                           Style="{StaticResource SubtitleTextBlockStyle}"
                                           FontWeight="SemiBold"
                                           FontSize="14" />
                                <TextBlock x:Name="ChineseTranslationText"
                                           Style="{StaticResource BodyTextBlockStyle}"
                                           TextWrapping="Wrap"
                                           FontSize="13"
                                           Visibility="Collapsed" />
                                <TextBlock x:Name="ExplanationText"
                                           Style="{StaticResource BodyTextBlockStyle}"
                                           TextWrapping="Wrap"
                                           FontSize="13" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- Row 1: 反馈横条 -->
            <Border Grid.Row="1"
                    x:Name="FeedbackBorder"
                    Visibility="Collapsed"
                    Height="40"
                    Margin="0,0,16,8"
                    CornerRadius="4"
                    Padding="12,0">
                <TextBlock x:Name="FeedbackTextBlock"
                           VerticalAlignment="Center"
                           Style="{StaticResource BodyTextBlockStyle}"
                           FontWeight="SemiBold"
                           FontSize="14" />
            </Border>

            <!-- Row 2: 底部导航栏 -->
            <Border Grid.Row="2"
                    x:Name="NavBar"
                    Visibility="Collapsed"
                    BorderBrush="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="0,8,16,0">
                <Grid MaxWidth="720" HorizontalAlignment="Stretch">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Content="上一题"
                            HorizontalAlignment="Left" Width="100"
                            FontSize="14"
                            Click="PreviousButton_Click" />

                    <TextBlock x:Name="NavProgressText" Grid.Column="1"
                               VerticalAlignment="Center"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"
                               FontSize="12" />

                    <Button Grid.Column="2" Content="下一题"
                            HorizontalAlignment="Right" Width="100"
                            FontSize="14"
                            Click="NextButton_Click"
                            Style="{StaticResource AccentButtonStyle}" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
