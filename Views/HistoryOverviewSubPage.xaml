<Page
    x:Class="QuizNative.Views.HistoryOverviewSubPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:QuizNative.ViewModels"
    mc:Ignorable="d">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="5*" />
            <ColumnDefinition Width="1*" />
        </Grid.ColumnDefinitions>

        <ScrollViewer Grid.Column="1"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="28"
                        Margin="0,28,0,48">

                <!-- ===== 页面标题 ===== -->
                <TextBlock Text="刷题履历与统计"
                           Style="{StaticResource TitleTextBlockStyle}"
                           FontWeight="SemiBold"
                           FontSize="22" />

                <!-- ===== 总进度主卡片 ===== -->
                <Border Background="{ThemeResource LayerOnMicaBaseAltFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="12" Padding="32,24">
                    <Grid RowSpacing="18">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Spacing="6">
                                <TextBlock Text="总解题进度"
                                           Style="{StaticResource BodyLargeTextBlockStyle}" FontWeight="SemiBold" FontSize="18"/>
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock x:Name="TotalPracticedLabel"
                                               Style="{StaticResource SubtitleTextBlockStyle}"
                                               FontWeight="Bold"
                                               FontSize="34"
                                               Foreground="{ThemeResource SystemAccentColor}"/>
                                    <TextBlock x:Name="TotalSuffixLabel"
                                               Style="{StaticResource BodyTextBlockStyle}"
                                               Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"
                                               VerticalAlignment="Bottom" Margin="0,0,0,6"/>
                                </StackPanel>
                            </StackPanel>

                            <TextBlock x:Name="TotalPercentageLabel"
                                       Grid.Column="1"
                                       Style="{StaticResource TitleTextBlockStyle}"
                                       FontSize="42"
                                       FontWeight="Black"
                                       Foreground="{ThemeResource SystemAccentColor}"
                                       VerticalAlignment="Center"/>
                        </Grid>

                        <ProgressBar Grid.Row="1" x:Name="TotalProgressBar"
                                     Maximum="100" Height="8" CornerRadius="4"/>
                    </Grid>
                </Border>

                <!-- ===== 两个概览小卡片（横向并排） ===== -->
                <Grid ColumnSpacing="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Background="{ThemeResource ControlFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                            BorderThickness="1" CornerRadius="10" Padding="24,20">
                        <StackPanel Orientation="Horizontal" Spacing="16">
                            <FontIcon Glyph="&#xE7BA;" FontSize="32" Foreground="Red" VerticalAlignment="Center"/>
                            <StackPanel>
                                <TextBlock Text="当前错题本存量"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"
                                           FontSize="13"/>
                                <TextBlock x:Name="WrongCountLabel"
                                           Style="{StaticResource BodyLargeTextBlockStyle}"
                                           FontWeight="Bold"
                                           FontSize="28"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1"
                            Background="{ThemeResource ControlFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                            BorderThickness="1" CornerRadius="10" Padding="24,20">
                        <StackPanel Orientation="Horizontal" Spacing="16">
                            <FontIcon Glyph="&#xE8B7;" FontSize="32"
                                      Foreground="{ThemeResource SystemAccentColor}" VerticalAlignment="Center"/>
                            <StackPanel>
                                <TextBlock Text="系统载入总题数"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"
                                           FontSize="13"/>
                                <TextBlock x:Name="TotalCountLabel"
                                           Style="{StaticResource BodyLargeTextBlockStyle}"
                                           FontWeight="Bold"
                                           FontSize="28"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>

                <Border Height="1"
                        Background="{ThemeResource ControlStrokeColorDefaultBrush}"
                        Opacity="0.3" />

                <!-- ===== 按章节查看履历标题 ===== -->
                <TextBlock Text="按章节查看履历"
                           Style="{StaticResource BodyLargeTextBlockStyle}"
                           FontWeight="SemiBold"
                           FontSize="17" />

                <!-- ===== 章节进度列表（横排网格展示） ===== -->
                <ItemsControl x:Name="ChapterList" />

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
