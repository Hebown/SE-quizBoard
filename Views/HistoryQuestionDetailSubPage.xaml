<Page
    x:Class="QuizNative.Views.HistoryQuestionDetailSubPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 顶部面包屑导航 -->
        <Border Grid.Row="0"
                BorderBrush="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                BorderThickness="0,0,0,1"
                Padding="24,12">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <HyperlinkButton x:Name="BackLink"
                                 Content="← 返回章节"
                                 Click="BackButton_Click"
                                 FontWeight="SemiBold" />
                <TextBlock Text=" / " VerticalAlignment="Center"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                <TextBlock x:Name="BreadcrumbTitle"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- 题目详情 -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Padding="32,24" Spacing="24" MaxWidth="800" HorizontalAlignment="Left">

                <!-- 履历统计卡片 -->
                <Border Background="{ThemeResource LayerOnMicaBaseAltFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" HorizontalAlignment="Center" Spacing="4">
                            <FontIcon Glyph="&#xE930;" FontSize="24" Foreground="Green" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="CorrectCountText"
                                       Style="{StaticResource SubtitleTextBlockStyle}"
                                       FontWeight="Bold" Foreground="Green"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="做对" Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" HorizontalAlignment="Center" Spacing="4">
                            <FontIcon Glyph="&#xE7BA;" FontSize="24" Foreground="Red" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="WrongCountText"
                                       Style="{StaticResource SubtitleTextBlockStyle}"
                                       FontWeight="Bold" Foreground="Red"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="做错" Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" HorizontalAlignment="Center" Spacing="4">
                            <FontIcon Glyph="&#xE9CE;" FontSize="24"
                                      Foreground="{ThemeResource SystemAccentColor}" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="TotalAttemptsText"
                                       Style="{StaticResource SubtitleTextBlockStyle}"
                                       FontWeight="Bold"
                                       Foreground="{ThemeResource SystemAccentColor}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="总答题次数" Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 题干（视觉降噪：纯文本直出） -->
                <StackPanel Spacing="8" Margin="0,0,0,8">
                    <TextBlock Text="题目内容"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                    <TextBlock x:Name="TopicText"
                               Style="{StaticResource BodyLargeTextBlockStyle}"
                               TextWrapping="Wrap"
                               FontSize="20"
                               FontWeight="Normal"
                               LineHeight="32" />
                </StackPanel>

                <!-- 正确答案标记 -->
                <Border x:Name="AnswerBadge"
                        Background="{ThemeResource SystemAccentColor}"
                        CornerRadius="4"
                        Padding="12,6"
                        HorizontalAlignment="Left">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE930;" FontSize="12" Foreground="White"/>
                        <TextBlock x:Name="AnswerText"
                                   Style="{StaticResource BodyTextBlockStyle}"
                                   FontWeight="SemiBold"
                                   Foreground="White"/>
                    </StackPanel>
                </Border>

                <!-- 选项列表（只读锁定） -->
                <ItemsControl x:Name="OptionsList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{ThemeResource ControlFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="16,12"
                                    Margin="0,0,0,8"
                                    HorizontalAlignment="Stretch"
                                    IsHitTestVisible="False">
                                <TextBlock Text="{Binding}"
                                           Style="{StaticResource BodyTextBlockStyle}"
                                           TextWrapping="Wrap"/>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
