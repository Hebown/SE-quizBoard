<Page
    x:Class="QuizNative.Views.HistoryQuestionDetailSubPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 顶部导航栏（全宽） -->
        <Border Grid.Row="0"
                BorderBrush="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                BorderThickness="0,0,0,1"
                Padding="28,12">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <HyperlinkButton x:Name="BackLink"
                                 Content="← 返回章节"
                                 Click="BackButton_Click"
                                 FontWeight="SemiBold"
                                 FontSize="14" />
                <TextBlock Text="/" VerticalAlignment="Center"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                <TextBlock x:Name="BreadcrumbTitle"
                           Style="{StaticResource BodyTextBlockStyle}"
                           FontWeight="SemiBold"
                           FontSize="15"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- 内容区 - 三列布局 -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="5*" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="1"
                            Spacing="24"
                            Margin="0,24,0,48">

                    <!-- ===== 履历统计卡片 ===== -->
                    <Border Background="{ThemeResource LayerOnMicaBaseAltFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" CornerRadius="12" Padding="28,24">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" HorizontalAlignment="Center" Spacing="6">
                                <FontIcon Glyph="&#xE930;" FontSize="32" Foreground="Green" HorizontalAlignment="Center"/>
                                <TextBlock x:Name="CorrectCountText"
                                           Style="{StaticResource SubtitleTextBlockStyle}"
                                           FontSize="32"
                                           FontWeight="Bold" Foreground="Green"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="做对" Style="{StaticResource BodyTextBlockStyle}"
                                           Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"
                                           HorizontalAlignment="Center" FontSize="14"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" HorizontalAlignment="Center" Spacing="6">
                                <FontIcon Glyph="&#xE7BA;" FontSize="32" Foreground="Red" HorizontalAlignment="Center"/>
                                <TextBlock x:Name="WrongCountText"
                                           Style="{StaticResource SubtitleTextBlockStyle}"
                                           FontSize="32"
                                           FontWeight="Bold" Foreground="Red"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="做错" Style="{StaticResource BodyTextBlockStyle}"
                                           Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"
                                           HorizontalAlignment="Center" FontSize="14"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2" HorizontalAlignment="Center" Spacing="6">
                                <FontIcon Glyph="&#xE9CE;" FontSize="32"
                                          Foreground="{ThemeResource SystemAccentColor}" HorizontalAlignment="Center"/>
                                <TextBlock x:Name="TotalAttemptsText"
                                           Style="{StaticResource SubtitleTextBlockStyle}"
                                           FontSize="32"
                                           FontWeight="Bold"
                                           Foreground="{ThemeResource SystemAccentColor}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="总答题次数" Style="{StaticResource BodyTextBlockStyle}"
                                           Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"
                                           HorizontalAlignment="Center" FontSize="14"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- ===== 题干卡片 ===== -->
                    <Border Background="{ThemeResource ControlFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                            BorderThickness="1" CornerRadius="10" Padding="24,20">
                        <StackPanel Spacing="16">
                            <TextBlock Text="题目内容"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"
                                       FontWeight="SemiBold"
                                       FontSize="13" />
                            <TextBlock x:Name="TopicText"
                                       Style="{StaticResource BodyLargeTextBlockStyle}"
                                       TextWrapping="Wrap"
                                       FontSize="16"
                                       FontWeight="Normal"
                                       LineHeight="26" />

                            <!-- 正确答案标记 -->
                            <Border x:Name="AnswerBadge"
                                    Background="{ThemeResource SystemAccentColor}"
                                    CornerRadius="6"
                                    Padding="14,8"
                                    HorizontalAlignment="Left">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE930;" FontSize="14" Foreground="White"/>
                                    <TextBlock x:Name="AnswerText"
                                               Style="{StaticResource BodyTextBlockStyle}"
                                               FontWeight="SemiBold"
                                               FontSize="14"
                                               Foreground="White"/>
                                </StackPanel>
                            </Border>

                            <!-- 分隔线 -->
                            <Border Height="1"
                                    Background="{ThemeResource ControlStrokeColorDefaultBrush}"
                                    Opacity="0.3" />

                            <!-- 选项列表 -->
                            <TextBlock Text="选项"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"
                                       FontWeight="SemiBold"
                                       FontSize="13" />
                            <ItemsControl x:Name="OptionsList" />
                        </StackPanel>
                    </Border>

                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
