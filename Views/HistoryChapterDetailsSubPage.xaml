<Page
    x:Class="QuizNative.Views.HistoryChapterDetailsSubPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 顶部面包屑导航 -->
        <Border Grid.Row="0"
                BorderBrush="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                BorderThickness="0,0,0,1"
                Padding="24,12">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <HyperlinkButton x:Name="BackLink"
                                 Content="← 返回总览"
                                 Click="BackButton_Click"
                                 FontWeight="SemiBold" />
                <TextBlock Text=" / " VerticalAlignment="Center"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                <TextBlock x:Name="ChapterTitleText"
                           Style="{StaticResource BodyTextBlockStyle}"
                           FontWeight="SemiBold" VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- 题目列表 -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Padding="32,24" Spacing="12" MaxWidth="800" HorizontalAlignment="Left">

                <TextBlock x:Name="SectionTitle" Text="本章节题目履历"
                           Style="{StaticResource SubtitleTextBlockStyle}" FontWeight="SemiBold"
                           Margin="0,0,0,8" />

                <ItemsControl x:Name="QuestionList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Stretch"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Padding="0" Margin="0,0,0,6"
                                    Click="QuestionItem_Click">
                                <Border Background="{ThemeResource ControlFillColorDefaultBrush}"
                                        BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                                        BorderThickness="1" CornerRadius="6"
                                        Padding="16,12" HorizontalAlignment="Stretch">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" Spacing="6">
                                            <TextBlock x:Name="QTopicText"
                                                       Style="{StaticResource BodyTextBlockStyle}"
                                                       TextWrapping="Wrap"
                                                       MaxHeight="48"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <StackPanel Orientation="Horizontal" Spacing="12">
                                                <StackPanel Orientation="Horizontal" Spacing="4">
                                                    <FontIcon Glyph="&#xE930;" FontSize="12" Foreground="Green"/>
                                                    <TextBlock x:Name="QCorrectText"
                                                               Style="{StaticResource CaptionTextBlockStyle}"
                                                               FontWeight="Bold" Foreground="Green"/>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Spacing="4">
                                                    <FontIcon Glyph="&#xE7BA;" FontSize="12" Foreground="Red"/>
                                                    <TextBlock x:Name="QWrongText"
                                                               Style="{StaticResource CaptionTextBlockStyle}"
                                                               FontWeight="Bold" Foreground="Red"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </StackPanel>

                                        <FontIcon Grid.Column="1" Glyph="&#xE76B;" FontSize="14"
                                                  Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"
                                                  VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
