<Page
    x:Class="QuizNative.Views.WrongQuestionsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}" Padding="32,24">
        <!-- 有错题时的内容区 -->
        <StackPanel x:Name="QuestionPanel" Visibility="Collapsed" Spacing="20" MaxWidth="800" HorizontalAlignment="Left">

            <TextBlock x:Name="TitleBlock" Text="错题消灭本"
                       Style="{StaticResource SubtitleTextBlockStyle}" FontWeight="SemiBold" />

            <StackPanel Spacing="16">
                <!-- 题干（视觉降噪：纯文本，无外框） -->
                <StackPanel Spacing="8" Margin="0,12,0,16">
                    <TextBlock x:Name="ProgressHeader"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                    <TextBlock x:Name="TopicText"
                               Style="{StaticResource BodyLargeTextBlockStyle}"
                               TextWrapping="Wrap"
                               FontSize="20"
                               FontWeight="Normal"
                               LineHeight="32" />
                </StackPanel>

                <!-- 选项列表 -->
                <ItemsControl x:Name="OptionsList" Margin="0,4,0,0" />

                <!-- 反馈横条 -->
                <Border x:Name="FeedbackBorder" Visibility="Collapsed"
                        BorderThickness="1" CornerRadius="6" Padding="16,12">
                    <TextBlock x:Name="FeedbackTextBlock"
                               Style="{StaticResource BodyTextBlockStyle}"
                               FontWeight="SemiBold" />
                </Border>
            </StackPanel>

            <!-- 下一道 -->
            <Button x:Name="NextButton" Content="下一道错题 →"
                    HorizontalAlignment="Right" Width="160"
                    Style="{StaticResource AccentButtonStyle}"
                    Click="NextButton_Click" />
        </StackPanel>

        <!-- 无错题空状态 -->
        <StackPanel x:Name="EmptyPanel" Visibility="Visible"
                    VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="16">
            <FontIcon Glyph="&#xE930;" FontSize="64" Foreground="Green" />
            <TextBlock Text="没有任何错题记录"
                       Style="{StaticResource TitleTextBlockStyle}"
                       HorizontalAlignment="Center" />
            <TextBlock Text="太厉害了！你的本地错题本空空如洗。"
                       Style="{StaticResource BodyTextBlockStyle}"
                       Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
        </StackPanel>
    </Grid>
</Page>
