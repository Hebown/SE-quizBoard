<Page
    x:Class="QuizNative.Views.WrongQuestionsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}" Padding="32,24">
        <!-- 有错题时的内容区 -->
        <StackPanel x:Name="QuestionPanel" Visibility="Collapsed" Spacing="16" MaxWidth="800" HorizontalAlignment="Left">

            <TextBlock x:Name="TitleBlock" Text="错题消灭本"
                       Style="{StaticResource SubtitleTextBlockStyle}" FontWeight="SemiBold" />

            <StackPanel Spacing="12">
                <!-- 题干 -->
                <StackPanel Spacing="6" Margin="0,8,0,12">
                    <TextBlock x:Name="ProgressHeader"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                    <TextBlock x:Name="TopicText"
                               Style="{StaticResource BodyLargeTextBlockStyle}"
                               TextWrapping="Wrap"
                               FontSize="16"
                               FontWeight="Normal"
                               LineHeight="26" />
                    <TextBlock x:Name="TranslationText"
                               Style="{StaticResource BodyTextBlockStyle}"
                               TextWrapping="Wrap"
                               Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"
                               FontStyle="Italic"
                               FontSize="14"
                               Visibility="Collapsed" />
                </StackPanel>

                <!-- 单选/判断题选项按钮 -->
                <ItemsControl x:Name="OptionsList" Margin="0,2,0,0" />

                <!-- 多选题复选框（默认隐藏） -->
                <ItemsControl x:Name="MultipleOptionsList" Margin="0,2,0,0" Visibility="Collapsed" />

                <!-- 多选题提交按钮 -->
                <Button x:Name="SubmitMultipleButton"
                        Content="提交多选题答案"
                        HorizontalAlignment="Stretch"
                        Margin="0,6,0,0"
                        Padding="12,8"
                        CornerRadius="4"
                        Style="{StaticResource AccentButtonStyle}"
                        Visibility="Collapsed"
                        Click="SubmitMultipleButton_Click" />

                <!-- 解析内容（回答后自动显示） -->
                <Border x:Name="ExplanationPanel"
                        Visibility="Collapsed"
                        Background="{ThemeResource SystemControlAcrylicWindowBrush}"
                        CornerRadius="4"
                        Padding="12,8"
                        Margin="0,2,0,0">
                    <StackPanel Spacing="6">
                        <TextBlock Text="题目解析"
                                   Style="{StaticResource SubtitleTextBlockStyle}"
                                   FontWeight="SemiBold"
                                   FontSize="14" />
                        <TextBlock x:Name="ChineseTranslationText"
                                   Style="{StaticResource BodyTextBlockStyle}"
                                   TextWrapping="Wrap"
                                   FontSize="13"
                                   Visibility="Collapsed" />
                        <TextBlock x:Name="ExplanationText"
                                   Style="{StaticResource BodyTextBlockStyle}"
                                   TextWrapping="Wrap"
                                   FontSize="13" />
                    </StackPanel>
                </Border>

                <!-- 反馈横条 -->
                <Border x:Name="FeedbackBorder" Visibility="Collapsed"
                        BorderThickness="1" CornerRadius="4" Padding="12,8">
                    <TextBlock x:Name="FeedbackTextBlock"
                               Style="{StaticResource BodyTextBlockStyle}"
                               FontWeight="SemiBold" />
                </Border>
            </StackPanel>

            <!-- 下一道 -->
            <Button x:Name="NextButton" Content="下一道错题"
                    HorizontalAlignment="Right" Width="140"
                    FontSize="14"
                    Style="{StaticResource AccentButtonStyle}"
                    Click="NextButton_Click" />
        </StackPanel>

        <!-- 无错题空状态 -->
        <StackPanel x:Name="EmptyPanel" Visibility="Visible"
                    VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="16">
            <FontIcon Glyph="&#xE930;" FontSize="64" Foreground="Green" />
            <TextBlock Text="没有任何错题记录"
                       Style="{StaticResource TitleTextBlockStyle}"
                       HorizontalAlignment="Center" />
            <TextBlock Text="太厉害了！你的本地错题本空空如洗。"
                       Style="{StaticResource BodyTextBlockStyle}"
                       Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
        </StackPanel>
    </Grid>
</Page>
